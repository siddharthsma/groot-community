# Groot Community environment template.
# Copy this to .env or run ./setup-community.sh to generate .env interactively.

# Image references
GROOT_API_IMAGE=ghcr.io/siddharthsma/groot-community-api:0.1.6
GROOT_UI_IMAGE=ghcr.io/siddharthsma/groot-community-ui:0.1.6
AGENT_RUNTIME_IMAGE=ghcr.io/siddharthsma/groot-community-agent-runtime:0.1.6
AI_GATEWAY_IMAGE=ghcr.io/siddharthsma/groot-community-ai-gateway:0.1.6

# Public runtime settings
# GROOT_PUBLIC_BASE_URL should point at the public API base URL used for event ingestion.
GROOT_PUBLIC_BASE_URL=http://localhost:8080
COMMUNITY_TENANT_NAME=Community Tenant
GROOT_UI_PORT=3000
GROOT_HTTP_PORT=8080
AGENT_RUNTIME_PORT=8090
AGENT_RUNTIME_LOG_LEVEL=info
AGENT_RUNTIME_DB_POOL_MIN=1
AGENT_RUNTIME_DB_POOL_MAX=10
AGENT_RUNTIME_DB_CONNECT_TIMEOUT_SECONDS=5
AGENT_RUNTIME_MODEL_TIMEOUT_SECONDS=60
AGENT_RUNTIME_MAX_TOOL_CALLS=16
AGENT_RUNTIME_TOOL_TIMEOUT_SECONDS=20
AI_GATEWAY_PORT=8787
TEMPORAL_PORT=7233
TEMPORAL_UI_PORT=8233
POSTGRES_PORT=5432
KAFKA_PORT=9092

# Generated or replaced by ./groot setup when left at placeholder values
GROOT_INSTALL_ID=community-install-id
GROOT_SECRETS_MASTER_KEY=community-secrets-master-key
GROOT_SYSTEM_API_KEY=system-secret
AI_GATEWAY_API_KEY=groot-ai-gateway-dev-key
AI_GATEWAY_STATUS_AUTH_API_KEY=ai-gateway-status-secret
AGENT_RUNTIME_SHARED_SECRET=agent-runtime-secret

# Optional telemetry settings
GROOT_TELEMETRY_ENABLED=true
GROOT_TELEMETRY_BASE_URL=https://telemetry.grootai.dev

# Optional observability settings
AI_GATEWAY_OTEL_WRITE_TOKEN=
AI_GATEWAY_OTEL_BASE_URL=
AI_GATEWAY_OTEL_EXPORTER_PROTOCOL=http/protobuf
AI_GATEWAY_LOGFIRE_TOKEN=

# Optional AI provider credentials
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
GROQ_API_KEY=
HF_TOKEN=
AGENT_RUNTIME_USE_GATEWAY=true
AGENT_RUNTIME_GATEWAY_REQUIRED=true
AI_GATEWAY_BASE_URL=http://ai-gateway:8787
