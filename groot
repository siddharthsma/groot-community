#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
COMPOSE_FILE="$SCRIPT_DIR/docker-compose.yml"
ENV_FILE="$SCRIPT_DIR/.env"
MIGRATIONS_DIR="$SCRIPT_DIR/migrations"

require_docker_compose() {
  if ! docker compose version >/dev/null 2>&1; then
    echo "Docker Compose is required." >&2
    exit 1
  fi
}

ensure_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    echo "Missing $ENV_FILE. Run ./setup-community.sh first." >&2
    exit 1
  fi
}

compose() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

run_migrations() {
  ensure_env
  require_docker_compose
  if [[ ! -d "$MIGRATIONS_DIR" ]]; then
    echo "Missing migrations directory: $MIGRATIONS_DIR" >&2
    exit 1
  fi

  while IFS= read -r file; do
    compose exec -T postgres psql -U groot -d groot < "$file"
  done < <(find "$MIGRATIONS_DIR" -type f -name '*.sql' | sort)
}

show_help() {
  cat <<'EOF'
Usage: groot <command>

Commands:
  setup [--non-interactive]  Configure .env for the Community bundle
  start                      Start the Community stack in detached mode
  stop                       Stop and remove the Community stack
  restart                    Restart the Community stack
  status                     Show Community stack status
  logs [service]             Tail logs for all services or one service
  migrate                    Apply SQL migrations from the bundle
  help                       Show this help text
EOF
}

cmd="${1:-help}"
shift || true

case "$cmd" in
  setup)
    exec "$SCRIPT_DIR/setup-community.sh" "$@"
    ;;
  start)
    ensure_env
    require_docker_compose
    compose up -d
    ;;
  stop)
    ensure_env
    require_docker_compose
    compose down
    ;;
  restart)
    ensure_env
    require_docker_compose
    compose down
    compose up -d
    ;;
  status)
    ensure_env
    require_docker_compose
    compose ps
    ;;
  logs)
    ensure_env
    require_docker_compose
    compose logs -f "$@"
    ;;
  migrate)
    run_migrations
    ;;
  help|-h|--help)
    show_help
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    show_help >&2
    exit 1
    ;;
esac
